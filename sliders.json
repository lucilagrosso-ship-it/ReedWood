{
  "version": "0.4",
  "title": "Reed Wood – Slider Hero",
  "type": "section",
  "content": [
    {
      "id": "rw-slider-section",
      "elType": "section",
      "settings": {
        "background_background": "classic",
        "background_color": "#0d0d0d",
        "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false },
        "margin": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false },
        "stretch_section": "section-stretched"
      },
      "elements": [
        {
          "id": "rw-slider-col",
          "elType": "column",
          "settings": { "_column_size": 100, "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false } },
          "elements": [
            {
              "id": "rw-slider-widget",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<style>*{box-sizing:border-box;margin:0;padding:0;}@keyframes kenBurns{from{transform:scale(1.06)}to{transform:scale(1)}}@keyframes revealLabel{from{opacity:0;letter-spacing:0.1em}to{opacity:1;letter-spacing:0.22em}}@keyframes revealUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}.rw-slider{position:relative;width:100%;height:100vh;min-height:560px;max-height:820px;overflow:hidden;background:#0d0d0d;font-family:'Georgia',serif;}.rw-slide{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;transition:opacity 1.2s ease;pointer-events:none;}.rw-slide.active{opacity:1;pointer-events:all;}.rw-slide img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(0.38);}.rw-slide.active img{animation:kenBurns 8s ease forwards;}.rw-slide::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 40%,rgba(0,0,0,0.55) 100%);}.rw-content{position:relative;z-index:2;text-align:center;max-width:700px;padding:2rem 2.5rem;display:flex;flex-direction:column;align-items:center;}.rw-label{font-family:system-ui,sans-serif;font-size:0.62rem;font-weight:400;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:1.5rem;opacity:0;transition:opacity 0.8s ease 0.3s,letter-spacing 0.8s ease 0.3s;}.rw-slide.active .rw-label{animation:revealLabel 0.8s ease 0.3s both;}.rw-heading{font-size:clamp(2rem,5vw,3.4rem);font-weight:400;line-height:1.15;color:#fff;letter-spacing:-0.01em;opacity:0;transform:translateY(20px);transition:opacity 0.8s ease 0.5s,transform 0.8s ease 0.5s;}.rw-slide.active .rw-heading{opacity:1;transform:translateY(0);}.rw-rule{width:0;height:1px;background:rgba(255,255,255,0.25);margin:1.75rem 0;transition:width 0.7s ease 0.95s,opacity 0.7s ease 0.95s;opacity:0;}.rw-slide.active .rw-rule{width:56px;opacity:1;}.rw-body{font-family:system-ui,sans-serif;font-size:0.92rem;font-weight:300;line-height:1.9;color:rgba(255,255,255,0.58);max-width:580px;opacity:0;transform:translateY(14px);transition:opacity 0.8s ease 1.05s,transform 0.8s ease 1.05s;}.rw-slide.active .rw-body{opacity:1;transform:translateY(0);}.rw-cta{display:inline-flex;align-items:center;gap:10px;margin-top:2.25rem;padding:0.8rem 2rem;font-family:system-ui,sans-serif;font-size:0.7rem;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;color:#fff;border:1px solid rgba(255,255,255,0.22);border-radius:1px;background:rgba(255,255,255,0.04);opacity:0;transform:translateY(10px);transition:opacity 0.7s ease 1.3s,transform 0.7s ease 1.3s,background 0.3s,border-color 0.3s;position:relative;overflow:hidden;}.rw-cta::before{content:'';position:absolute;inset:0;background:#e93d1b;transform:scaleX(0);transform-origin:left;transition:transform 0.35s ease;z-index:-1;}.rw-cta:hover::before{transform:scaleX(1);}.rw-cta:hover{border-color:#e93d1b;}.rw-cta svg{width:13px;height:13px;stroke:#fff;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;transition:transform 0.25s;}.rw-cta:hover svg{transform:translateX(4px);}.rw-slide.active .rw-cta{opacity:1;transform:translateY(0);}.rw-prev,.rw-next{position:absolute;top:50%;transform:translateY(-50%);z-index:10;background:none;border:none;cursor:pointer;padding:1.25rem;outline:none;opacity:0.3;transition:opacity 0.3s;}.rw-prev:hover,.rw-next:hover{opacity:1;}.rw-prev{left:2rem;}.rw-next{right:2rem;}.rw-prev svg,.rw-next svg{width:22px;height:22px;stroke:#fff;fill:none;stroke-width:1;stroke-linecap:round;stroke-linejoin:round;}.rw-dots{position:absolute;right:2.5rem;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:12px;z-index:10;}.rw-dot{width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,0.25);border:none;cursor:pointer;padding:0;transition:height 0.35s,background 0.35s,border-radius 0.35s;}.rw-dot.active{height:32px;border-radius:2px;background:#fff;}.rw-counter{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);z-index:10;font-family:system-ui,sans-serif;font-size:0.65rem;letter-spacing:0.2em;color:rgba(255,255,255,0.25);}.rw-counter span{color:rgba(255,255,255,0.7);}.rw-progress{position:absolute;bottom:0;left:0;height:1px;background:rgba(255,255,255,0.35);width:0;z-index:10;}</style><div class=\"rw-slider\" id=\"rw-slider\"><div class=\"rw-slide active\"><img src=\"https://reedwood12968.e.wpstage.net/bv-wp-content/uploads/2026/03/Parallel-H-3-2.jpeg\" alt=\"\"><div class=\"rw-content\"><span class=\"rw-label\">Mass Timber · Reed Wood</span><h2 class=\"rw-heading\">Construimos el Futuro<br>con Madera de Ingeniería</h2><div class=\"rw-rule\"></div><p class=\"rw-body\">Soluciones estructurales sustentables con la tecnología Mass Timber. Desarrollamos, producimos y montamos sistemas constructivos de alto rendimiento.</p><a href=\"#contacto\" class=\"rw-cta\">Contactanos <svg viewBox=\"0 0 24 24\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg></a></div></div><div class=\"rw-slide\"><img src=\"https://reedwood12968.e.wpstage.net/bv-wp-content/uploads/2026/03/WhatsApp-Image-2026-02-26-at-12.19.08-PM-3.jpeg\" alt=\"\"><div class=\"rw-content\"><span class=\"rw-label\">Innovación · Reed Wood</span><h2 class=\"rw-heading\">El Sistema Constructivo que<br>Transforma tus Proyectos</h2><div class=\"rw-rule\"></div><p class=\"rw-body\">Mass Timber abre nuevas posibilidades arquitectónicas: estructuras más limpias, cálidas, modernas y sustentables, con el respaldo técnico de Reed Wood.</p><a href=\"#contacto\" class=\"rw-cta\">Contactanos <svg viewBox=\"0 0 24 24\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg></a></div></div><div class=\"rw-slide\"><img src=\"https://reedwood12968.e.wpstage.net/bv-wp-content/uploads/2026/03/WhatsApp-Image-2026-02-26-at-12.19.08-PM-3.jpeg\" alt=\"\"><div class=\"rw-content\"><span class=\"rw-label\">Sustentabilidad · Reed Wood</span><h2 class=\"rw-heading\">Arquitectura Sustentable<br>con Madera de Ingeniería</h2><div class=\"rw-rule\"></div><p class=\"rw-body\">Reducimos el impacto ambiental y elevamos la calidad estructural mediante soluciones Mass Timber certificadas, diseñadas para un futuro más responsable.</p><a href=\"#contacto\" class=\"rw-cta\">Contactanos <svg viewBox=\"0 0 24 24\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg></a></div></div><button class=\"rw-prev\" id=\"rw-prev\" aria-label=\"Anterior\"><svg viewBox=\"0 0 24 24\"><polyline points=\"15 18 9 12 15 6\"/></svg></button><button class=\"rw-next\" id=\"rw-next\" aria-label=\"Siguiente\"><svg viewBox=\"0 0 24 24\"><polyline points=\"9 6 15 12 9 18\"/></svg></button><div class=\"rw-dots\" id=\"rw-dots\"><button class=\"rw-dot active\"></button><button class=\"rw-dot\"></button><button class=\"rw-dot\"></button></div><div class=\"rw-counter\"><span id=\"rw-cur\">01</span> / 03</div><div class=\"rw-progress\" id=\"rw-progress\"></div></div><script>!function(){const slides=document.querySelectorAll('.rw-slide'),dots=document.querySelectorAll('.rw-dot'),cur=document.getElementById('rw-cur'),prog=document.getElementById('rw-progress'),DUR=6000;let current=0,timer;function pad(n){return String(n+1).padStart(2,'0')}function goTo(n){slides[current].classList.remove('active');dots[current].classList.remove('active');current=(n+slides.length)%slides.length;slides[current].classList.add('active');dots[current].classList.add('active');cur.textContent=pad(current);anim()}function anim(){prog.style.transition='none';prog.style.width='0%';requestAnimationFrame(()=>requestAnimationFrame(()=>{prog.style.transition=`width ${DUR}ms linear`;prog.style.width='100%'}))}function start(){clearInterval(timer);timer=setInterval(()=>goTo(current+1),DUR)}document.getElementById('rw-prev').onclick=()=>{goTo(current-1);start()};document.getElementById('rw-next').onclick=()=>{goTo(current+1);start()};dots.forEach((d,i)=>d.onclick=()=>{goTo(i);start()});anim();start()}();<\/script>"
              }
            }
          ]
        }
      ]
    }
  ]
}